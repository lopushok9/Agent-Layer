# Inbound auth for clients calling the gateway.
REQUIRE_BEARER_AUTH=false
PROVIDER_GATEWAY_BEARER_TOKEN=

# Optional CORS for browser-based callers.
ALLOWED_ORIGINS=

# Shared Solana RPC. Pick one strategy:
# 1) set SHARED_SOLANA_RPC_URL directly, or
# 2) set HELIUS_API_KEY, or
# 3) set ALCHEMY_API_KEY.
SHARED_SOLANA_RPC_URL=
HELIUS_API_KEY=
HELIUS_SHARED_RPC_URL=
ALCHEMY_API_KEY=
ALCHEMY_SHARED_RPC_URL=

# Shared EVM RPC. Ethereum/Base/Robinhood can either use explicit shared URLs,
# explicit Alchemy URLs, or be derived from ALCHEMY_API_KEY.
SHARED_EVM_ETHEREUM_RPC_URL=
SHARED_EVM_BASE_RPC_URL=
SHARED_EVM_ROBINHOOD_RPC_URL=
ALCHEMY_ETHEREUM_RPC_URL=
ALCHEMY_BASE_RPC_URL=
ALCHEMY_ROBINHOOD_RPC_URL=

# Bags API
BAGS_API_KEY=
BAGS_API_BASE_URL=https://public-api-v2.bags.fm/api/v1

# Jupiter Earn API
JUPITER_API_KEY=
JUPITER_LEND_API_BASE_URL=https://api.jup.ag/lend/v1

# Uniswap Trading API (the EVM wallet daemon routes quotes/swaps through here so
# the key never ships to client machines). UNISWAP_API_KEY is required to enable
# the /v1/evm/uniswap/* routes; the base URL/router version have working defaults.
UNISWAP_API_KEY=
UNISWAP_TRADING_API_BASE_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_ROUTER_VERSION=2.0

# Flash Trade read relay
FLASH_API_BASE_URL=

# Houdini Partner API
HOUDINI_API_KEY=
HOUDINI_API_SECRET=
HOUDINI_API_BASE_URL=https://api-partner.houdiniswap.com/v2
HOUDINI_USER_AGENT=AgentLayer/provider-gateway
HOUDINI_USER_TIMEZONE=UTC

# Runtime
HTTP_TIMEOUT_SECONDS=20
PORT=8000
