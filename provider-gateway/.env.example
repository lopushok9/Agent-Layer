# Inbound auth for clients calling the gateway.
REQUIRE_BEARER_AUTH=false
PROVIDER_GATEWAY_BEARER_TOKEN=

# Optional CORS for browser-based callers.
ALLOWED_ORIGINS=

# Shared Solana RPC. Pick one strategy:
# 1) set SHARED_SOLANA_RPC_URL directly, or
# 2) set HELIUS_API_KEY, or
# 3) set ALCHEMY_API_KEY.
SHARED_SOLANA_RPC_URL=
HELIUS_API_KEY=
HELIUS_SHARED_RPC_URL=
ALCHEMY_API_KEY=
ALCHEMY_SHARED_RPC_URL=

# Shared EVM RPC. Ethereum/Base can either use explicit shared URLs,
# explicit Alchemy URLs, or be derived from ALCHEMY_API_KEY.
SHARED_EVM_ETHEREUM_RPC_URL=
SHARED_EVM_BASE_RPC_URL=
ALCHEMY_ETHEREUM_RPC_URL=
ALCHEMY_BASE_RPC_URL=

# Bags API
BAGS_API_KEY=
BAGS_API_BASE_URL=https://public-api-v2.bags.fm/api/v1

# Jupiter Earn API
JUPITER_API_KEY=
JUPITER_LEND_API_BASE_URL=https://api.jup.ag/lend/v1

# Runtime
HTTP_TIMEOUT_SECONDS=20
PORT=8000
