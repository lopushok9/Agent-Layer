{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/wallet", "destination": "/wallet/" },
    { "source": "/mcp", "destination": "/mcp/" },
    { "source": "/use-cases", "destination": "/use-cases/" },
    { "source": "/how-to-use", "destination": "/how-to-use/" },
    { "source": "/for-investors", "destination": "/for-investors/" },
    { "source": "/about", "destination": "/about/" },
    { "source": "/terms", "destination": "/terms/" },
    { "source": "/onboard", "destination": "/onboard/" },
    { "source": "/product", "destination": "/mcp/" },
    { "source": "/about-agent-layer", "destination": "/about/" }
  ]
}
