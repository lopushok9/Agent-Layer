<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 | AgentLayer Docs</title>
    <meta name="description" content="Page not found." />
    <link rel="icon" href="/favicon.svg" />
    <style>
      :root {
        color-scheme: light;
        --bg: #f4f7fb;
        --fg: #0b1220;
        --muted: #5d6b82;
        --card: #ffffff;
        --line: #d6deeb;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background: radial-gradient(circle at top, #ffffff, var(--bg));
        color: var(--fg);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      main {
        width: min(100%, 640px);
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 32px;
        box-shadow: 0 24px 60px rgba(11, 18, 32, 0.08);
      }

      h1 {
        margin: 0 0 12px;
        font-size: 2.5rem;
        line-height: 1;
      }

      p {
        margin: 0 0 18px;
        color: var(--muted);
        line-height: 1.6;
      }

      a {
        display: inline-block;
        padding: 10px 14px;
        border-radius: 10px;
        background: var(--fg);
        color: #fff;
        text-decoration: none;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>404</h1>
      <p>The page you requested was not found.</p>
      <a href="/">Back to docs</a>
    </main>
  </body>
  </html>
